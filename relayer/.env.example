# Sepolia testnet RPC endpoint
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Polygon Amoy testnet RPC endpoint
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Private key for the relayer account (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Lock contract address on Sepolia
LOCK_CONTRACT_ADDRESS=0x...

# Mint contract address on Amoy
MINT_CONTRACT_ADDRESS=0x...

